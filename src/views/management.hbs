<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="fw-bold">♥ Management <span class="text-secondary fs-4">(Control Panel)</span></h1>
        {{#if canEdit}}
        <a href="/love-view/create" class="btn btn-primary">+ Add New Series</a>
        {{/if}}
    </div>

    <div class="mb-4 d-flex">
        <div class="d-inline-flex bg-white p-2 border border-2 border-dark rounded-pill gap-2 shadow-sm">
            <a href="/love-view/management" class="btn btn-sm {{#unless currentStatus}}btn-primary{{else}}btn-outline-accent{{/unless}} rounded-pill px-4 border-0">Todos los Estados</a>
            <a href="/love-view/management?status=Watching" class="btn btn-sm {{#if (eq currentStatus 'Watching')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Viendo</a>
            <a href="/love-view/management?status=Plan to Watch" class="btn btn-sm {{#if (eq currentStatus 'Plan to Watch')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Por ver</a>
            <a href="/love-view/management?status=Watched" class="btn btn-sm {{#if (eq currentStatus 'Watched')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Vistas</a>
        </div>
    </div>

    <div class="glass-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Title</th>
                        <th class="py-3">Type</th>
                        <th class="py-3">Genre</th>
                        <th class="py-3">Status</th>
                        <th class="py-3">Rating</th>
                        {{#if canEdit}}
                        <th class="py-3 text-end pe-4">Actions</th>
                        {{/if}}
                    </tr>
                </thead>
                <tbody>
                    {{#each series}}
                    <tr class="align-middle">
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="{{posterUrl}}" alt="" style="width: 40px; height: 60px; object-fit: cover; border-radius: 4px;">
                                <span class="fw-bold">{{title}}</span>
                            </div>
                        </td>
                        <td>
                            <span class="text-secondary small">
                                {{type}}{{#if (eq type 'Serie')}}{{#if season}} (T{{season}}){{/if}}{{/if}}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex flex-wrap align-items-center gap-1">
                                <span class="badge" style="background: var(--accent-color); color: var(--dark-accent);">{{Genre.name}}</span>
                                {{#if Genre2.name}}<span class="badge small" style="background: var(--accent-color); color: var(--dark-accent);">{{Genre2.name}}</span>{{/if}}
                                {{#if Genre3.name}}<span class="badge small" style="background: var(--accent-color); color: var(--dark-accent);">{{Genre3.name}}</span>{{/if}}
                                {{#if Genre4.name}}<span class="badge small" style="background: var(--accent-color); color: var(--dark-accent);">{{Genre4.name}}</span>{{/if}}
                            </div>
                        </td>
                        <td>
                            <span class="badge {{#if (eq status 'Watching')}}bg-primary{{/if}} {{#if (eq status 'Watched')}}bg-success{{/if}} {{#if (eq status 'Plan to Watch')}}bg-secondary{{/if}}">
                                {{status}}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <i class="fas fa-star text-warning small"></i>
                                <span class="fw-bold">{{#if ratingAverage}}{{ratingAverage}}{{else}}0.0{{/if}}</span>
                            </div>
                        </td>
                        {{#if @root.canEdit}}
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="/love-view/edit/{{id}}" class="btn btn-outline-accent btn-sm">Edit</a>
                                <a href="/love-view/delete/{{id}}" class="btn btn-danger btn-sm" onclick="return confirm('Delete this series?')">Delete</a>
                            </div>
                        </td>
                        {{/if}}
                    </tr>
                    {{/each}}
                    {{#unless series.length}}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-secondary italic">No series found. Click "+ Add New" to start.</td>
                    </tr>
                    {{/unless}}
                </tbody>
            </table>
        </div>
    </div>
</div>
