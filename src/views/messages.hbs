<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="fw-bold"><i class="fas fa-comment-dots text-info me-3"></i> Messages Dashboard</h1>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Emi's Column -->
        {{#unless (eq user.username 'emi')}}
        <div class="col-md-10 col-lg-6">
            <div class="glass-card p-4 h-100" style="border-top: 5px solid var(--accent-color);">
                <h3 class="fw-bold text-center mb-4" style="color: var(--dark-accent);">Mensajes para Emi</h3>
                
                {{#if canEdit}}
                <form action="/messages/create/emi" method="POST" class="mb-4">
                    <div class="input-group drop-shadow-sm">
                        <input type="text" name="content" class="form-control" placeholder="Escribe algo bonito..." required style="border: none;">
                        <button class="btn btn-primary px-4" type="submit"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </form>
                {{/if}}

                <div class="messages-container d-flex flex-column gap-3 pe-2" style="max-height: 500px; overflow-y: auto;">
                    {{#each messagesEmi}}
                    <div class="p-3 rounded shadow-sm bg-white position-relative transition-all" style="border-left: 4px solid var(--accent-color);">
                        <p class="mb-1" style="font-size: 1.05rem; word-break: break-word;">{{content}}</p>
                        <small class="text-secondary" style="font-size: 0.75rem;">{{formattedDate}}</small>
                        {{#if @root.canEdit}}
                        <a href="/messages/delete/emi/{{id}}" class="text-danger position-absolute top-0 end-0 p-2 opacity-50 hover-opacity-100" onclick="return confirm('¿Seguro de borrar este mensaje?')">
                            <i class="fas fa-trash-alt"></i>
                        </a>
                        {{/if}}
                    </div>
                    {{else}}
                    <div class="text-center py-5">
                        <i class="fas fa-envelope-open-text text-secondary opacity-25" style="font-size: 3rem;"></i>
                        <p class="text-secondary italic mt-3">No hay mensajes para Emi todavía.</p>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>
        {{/unless}}

        <!-- Deli's Column -->
        {{#unless (eq user.username 'deli')}}
        <div class="col-md-10 col-lg-6">
            <div class="glass-card p-4 h-100" style="border-top: 5px solid #9c27b0;">
                <h3 class="fw-bold text-center mb-4" style="color: #9c27b0;">Mensajes para Deli</h3>
                
                {{#if canEdit}}
                <form action="/messages/create/deli" method="POST" class="mb-4">
                    <div class="input-group drop-shadow-sm">
                        <input type="text" name="content" class="form-control" placeholder="Escribe algo bonito..." required style="border: none;">
                        <button class="btn btn-primary px-4" type="submit" style="background-color: #9c27b0; border-color: #9c27b0;"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </form>
                {{/if}}

                <div class="messages-container d-flex flex-column gap-3 pe-2" style="max-height: 500px; overflow-y: auto;">
                    {{#each messagesDeli}}
                    <div class="p-3 rounded shadow-sm bg-white position-relative transition-all" style="border-left: 4px solid #9c27b0;">
                        <p class="mb-1" style="font-size: 1.05rem; word-break: break-word;">{{content}}</p>
                        <small class="text-secondary" style="font-size: 0.75rem;">{{formattedDate}}</small>
                        {{#if @root.canEdit}}
                        <a href="/messages/delete/deli/{{id}}" class="text-danger position-absolute top-0 end-0 p-2 opacity-50 hover-opacity-100" onclick="return confirm('¿Seguro de borrar este mensaje?')">
                            <i class="fas fa-trash-alt"></i>
                        </a>
                        {{/if}}
                    </div>
                    {{else}}
                    <div class="text-center py-5">
                        <i class="fas fa-envelope-open-text text-secondary opacity-25" style="font-size: 3rem;"></i>
                        <p class="text-secondary italic mt-3">No hay mensajes para Deli todavía.</p>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>
        {{/unless}}
    </div>
</div>

<style>
    .messages-container::-webkit-scrollbar {
        width: 6px;
    }
    .messages-container::-webkit-scrollbar-track {
        background: transparent;
    }
    .messages-container::-webkit-scrollbar-thumb {
        background: rgba(0,0,0,0.1);
        border-radius: 10px;
    }
    .hover-opacity-100:hover {
        opacity: 1 !important;
    }
</style>
