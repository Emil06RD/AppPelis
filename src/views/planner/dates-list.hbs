<div class="row mb-4 align-items-center fade-in">
    <div class="col">
        <h2 class="fw-bold mb-0" style="color: var(--dark-accent);">
            <i class="fas fa-heart text-primary me-2"></i>Nuestras Citas Anteriores
        </h2>
    </div>
    <div class="col-auto d-flex gap-2">
        <a href="/places" class="btn btn-outline-secondary transition-all">
            <i class="fas fa-map-marked-alt me-2"></i>Lugares Recomendados
        </a>
        <a href="/dates/create" class="btn btn-primary transition-all shadow-sm">
            <i class="fas fa-plus me-2"></i>Registrar Cita
        </a>
    </div>
</div>

<div class="row g-4 fade-in" style="animation-delay: 0.1s;">
    {{#if dates.length}}
    {{#each dates}}
    <!-- Elegante Tarjeta Fija -->
    <div class="col-6 col-md-4 col-lg-3">
        <a href="/dates/view/{{this.id}}" class="text-decoration-none d-block h-100">
            <div class="glass-card p-2 h-100 transition-all app-card border-0 shadow-sm bg-white" style="border-radius: 16px;">
                <div class="position-relative overflow-hidden" style="border-radius: 12px; height: 180px;">
                    {{#if this.DatePhotos.length}}
                    <img src="{{this.DatePhotos.[0].photo_url}}" alt="Cita" class="w-100 h-100 transition-all card-img-hover" style="object-fit: cover;">
                    {{else}}
                    <div class="w-100 h-100 bg-dark d-flex align-items-center justify-content-center">
                        <i class="fas fa-camera text-muted fs-1 opacity-25 text-white"></i>
                    </div>
                    {{/if}}
                </div>
                <div class="p-3 pb-2 text-start">
                    <h6 class="fw-bold mb-1 text-dark text-truncate" title="{{this.title}}">{{#if this.title}}{{this.title}}{{else}}Cita Especial{{/if}}</h6>
                    <p class="mb-2 small text-primary fw-bold text-truncate"><i class="fas fa-map-marker-alt me-1"></i>{{this.Places.name}}</p>
                    <div class="text-muted border-top pt-2 mt-2" style="font-size: 0.75rem;">
                        <i class="fas fa-calendar-alt me-1"></i>{{this.formattedDateTime}}
                    </div>
                </div>
            </div>
        </a>
    </div>
    {{/each}}
    {{/if}}
</div>


    {{#unless dates.length}}
    <div class="col-12 text-center py-5">
        <div class="glass-card p-5">
            <i class="fas fa-camera-retro text-muted fs-1 mb-3"></i>
            <h4 class="text-secondary">Aún no hay citas registradas</h4>
            <p class="text-muted mb-4">¡Guarda el recuerdo de su primera salida juntos!</p>
            <a href="/dates/create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Registrar Cita
            </a>
        </div>
    </div>
    {{/unless}}
</div>

<style>
    .app-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(255,105,180,0.15) !important; }
    .card-img-hover { transition: transform 0.4s ease, filter 0.4s ease; }
    .app-card:hover .card-img-hover { transform: scale(1.08); filter: brightness(1.05); }
</style>
