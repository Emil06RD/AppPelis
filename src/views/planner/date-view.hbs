<!-- Hero Section with Album Cover/Collage -->
<div class="container-fluid p-0 mb-5 position-relative fade-in shadow" style="height: 60vh; min-height: 400px; background-color: #111;">
    {{#if date.DatePhotos.length}}
    <!-- CSS Grid Collage Area -->
    <div class="photo-collage photo-count-{{date.DatePhotos.length}} w-100 h-100">
        {{#each date.DatePhotos}}
        <div class="collage-item collage-item-{{@index}} h-100 w-100 position-relative">
            <img src="{{this.photo_url}}" class="w-100 h-100" style="object-fit: cover; opacity: 0.9;" alt="Recuerdo">
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="h-100 w-100 d-flex align-items-center justify-content-center bg-dark" style="opacity: 0.3;">
        <i class="fas fa-heart text-muted" style="font-size: 8rem;"></i>
    </div>
    {{/if}}

    <!-- Title Overlay Over Photos -->
    <div class="position-absolute bottom-0 start-0 w-100 p-5 title-overlay-gradient" style="z-index:10; pointer-events: none;">
        <h1 class="display-3 fw-bold text-white text-shadow text-capitalize mb-2" style="font-family: 'Playfair Display', serif;">{{#if date.title}}{{date.title}}{{else}}Cita Especial{{/if}}</h1>
        <h3 class="text-white opacity-75 fw-light mb-2"><i class="fas fa-map-marker-alt text-primary me-3"></i>{{date.Places.name}}</h3>
        <h5 class="text-light mb-0 fw-light"><i class="fas fa-calendar-alt text-info me-3"></i>{{date.formattedDateTime}}</h5>
        <div class="mt-4" style="pointer-events: auto;">
            <a href="/dates" class="btn btn-outline-light rounded-pill px-4 py-2 me-2 mb-2 transition-all"><i class="fas fa-arrow-left me-2"></i>Muro</a>
            {{#if canEdit}}
            <a href="/dates/edit/{{date.id}}" class="btn btn-primary rounded-pill px-4 py-2 me-2 mb-2 transition-all"><i class="fas fa-edit me-2"></i>Editar / Fotos</a>
            <form action="/dates/delete/{{date.id}}" method="GET" class="d-inline" onsubmit="return confirm('¿Seguro de que quieres eliminar este hermoso recuerdo para siempre?');">
                <button type="submit" class="btn btn-outline-danger rounded-pill px-4 py-2 mb-2 transition-all">
                    <i class="fas fa-trash-alt me-2"></i>Eliminar
                </button>
            </form>
            {{/if}}
        </div>
    </div>
</div>

<!-- Detailed Description Container below -->
<div class="container fade-in" style="animation-delay: 0.2s;">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <div class="glass-card shadow-lg p-5 border-0 text-center position-relative z-index-2" style="transform: translateY(-50px);">
                <i class="fas fa-quote-left fs-1 text-primary opacity-25 mb-4 d-block"></i>
                
                {{#if date.description}}
                <p class="fs-4 text-dark fst-italic mx-md-4" style="line-height: 1.8;">{{date.description}}</p>
                {{else}}
                <p class="fs-4 text-muted fst-italic mx-md-4">Un recuerdo perfecto merece ser descrito. Edita esta cita para anotar los mejores momentos que vivieron aquí.</p>
                {{/if}}
                
                <i class="fas fa-quote-right fs-1 text-primary opacity-25 mt-4 d-block"></i>
            </div>
        </div>
    </div>
</div>

<style>
    .title-overlay-gradient {
        background: linear-gradient(to top, rgba(0, 0, 0, 0.95) 0%, rgba(0, 0, 0, 0.7) 40%, rgba(0, 0, 0, 0) 100%);
    }
    
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

    /* Estilos del Collage de Fotos */
    .photo-collage {
        display: grid;
        gap: 4px;
        background-color: #000;
    }
    .collage-item { overflow: hidden; }

    /* Lógica del Grid según cantidad de fotos */
    .photo-count-1 { grid-template-columns: 1fr; }
    .photo-count-2 { grid-template-columns: 1fr 1fr; }
    
    .photo-count-3, .photo-count-4, .photo-count-5 { 
        grid-template-columns: 2fr 1fr 1fr; 
        grid-template-rows: 1fr 1fr;
    }
    
    .photo-count-3 .collage-item-0 { grid-column: 1 / 2; grid-row: 1 / 3; }
    .photo-count-3 .collage-item-1 { grid-column: 2 / 4; grid-row: 1 / 2; }
    .photo-count-3 .collage-item-2 { grid-column: 2 / 4; grid-row: 2 / 3; }

    .photo-count-4 .collage-item-0 { grid-column: 1 / 2; grid-row: 1 / 3; }
    .photo-count-4 .collage-item-1 { grid-column: 2 / 3; grid-row: 1 / 2; }
    .photo-count-4 .collage-item-2 { grid-column: 3 / 4; grid-row: 1 / 2; }
    .photo-count-4 .collage-item-3 { grid-column: 2 / 4; grid-row: 2 / 3; }

    .photo-count-5 .collage-item-0 { grid-column: 1 / 2; grid-row: 1 / 3; }
    .photo-count-5 .collage-item-1 { grid-column: 2 / 3; grid-row: 1 / 2; }
    .photo-count-5 .collage-item-2 { grid-column: 3 / 4; grid-row: 1 / 2; }
    .photo-count-5 .collage-item-3 { grid-column: 2 / 3; grid-row: 2 / 3; }
    .photo-count-5 .collage-item-4 { grid-column: 3 / 4; grid-row: 2 / 3; }
</style>
