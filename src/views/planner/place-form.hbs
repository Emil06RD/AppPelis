<div class="row justify-content-center fade-in">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card p-5">
            <div class="d-flex align-items-center mb-4">
                <a href="/places" class="btn btn-outline-secondary btn-sm me-3 transition-all">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <h3 class="fw-bold mb-0 text-dark">{{title}}</h3>
            </div>

            <form action="{{#if editMode}}/places/edit/{{place.id}}{{else}}/places/create{{/if}}" method="POST">
                
                <div class="mb-4">
                    <label for="name" class="form-label fw-semibold">Nombre del Lugar <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-map-marker-alt text-primary"></i></span>
                        <input type="text" class="form-control border-start-0" id="name" name="name" 
                            value="{{place.name}}" required placeholder="Ej: Restaurante, Parque, Museo..."
                            style="background-color: rgba(255,255,255,0.5);">
                    </div>
                </div>

                <div class="mb-4">
                    <label for="location_url" class="form-label fw-semibold">Enlace (Google Maps, etc.)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-link text-info"></i></span>
                        <input type="url" class="form-control border-start-0" id="location_url" name="location_url" 
                            value="{{place.location_url}}" placeholder="https://maps.google.com/..."
                            style="background-color: rgba(255,255,255,0.5);">
                    </div>
                </div>

                <div class="mb-4">
                    <label for="description" class="form-label fw-semibold">Descripción / Notas</label>
                    <textarea class="form-control" id="description" name="description" rows="4" 
                        placeholder="Detalles sobre por qué ir, qué pedir, horarios..."
                        style="background-color: rgba(255,255,255,0.5);">{{place.description}}</textarea>
                </div>

                <div class="mb-4">
                    <label for="photo_url" class="form-label fw-semibold">URL de la Foto de Portada (Enlace)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-camera text-secondary"></i></span>
                        <input type="url" class="form-control border-start-0" id="photo_url" name="photo_url" value="{{place.photo_url}}" placeholder="https://..."
                            style="background-color: rgba(255,255,255,0.5);">
                    </div>
                    {{#if place.photo_url}}
                    <div class="mt-2 text-center">
                        <img src="{{place.photo_url}}" alt="Lugar" class="img-fluid rounded shadow-sm" style="max-height: 150px; object-fit: cover;">
                    </div>
                    {{/if}}
                </div>

                <div class="d-grid mt-5">
                    <button type="submit" class="btn btn-primary btn-lg transition-all shadow-sm">
                        <i class="fas {{#if editMode}}fa-save{{else}}fa-plus{{/if}} me-2"></i>{{#if editMode}}Guardar Cambios{{else}}Registrar Lugar{{/if}}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
