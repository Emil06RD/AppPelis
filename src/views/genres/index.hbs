<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="fw-bold">♥ Manage Genres</h1>
        <a href="/genres/create" class="btn btn-primary">+ Add New Genre</a>
    </div>

    <div class="glass-card p-0 overflow-hidden" style="max-width: 600px; margin: 0 auto;">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Name</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each genres}}
                    <tr class="align-middle">
                        <td class="ps-4 fw-bold">{{name}}</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="/genres/edit/{{id}}" class="btn btn-outline-accent btn-sm">Edit</a>
                                <a href="/genres/delete/{{id}}" class="btn btn-danger btn-sm" onclick="return confirm('Delete this genre?')">Delete</a>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                    {{#unless genres.length}}
                    <tr>
                        <td colspan="2" class="text-center py-5 text-secondary italic">No genres found.</td>
                    </tr>
                    {{/unless}}
                </tbody>
            </table>
        </div>
    </div>
</div>
