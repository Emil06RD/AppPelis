<div class="row min-vh-100 align-items-center justify-content-center fade-in">
    <div class="col-md-6 col-lg-5 text-center">
        
        <div class="mb-4">
            <h1 class="display-5 fw-bold mb-3"><span class="text-primary">Love View</span> Access</h1>
            <p class="text-secondary">Please identify yourself to continue.</p>
        </div>

        <div class="glass-card p-5 text-start shadow-lg" style="border-top: 5px solid var(--accent-color);">
            {{#if error}}
            <div class="alert alert-danger shadow-sm border-0" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>{{error}}
            </div>
            {{/if}}

            <form action="/login" method="POST">
                <div class="mb-4">
                    <label for="username" class="form-label fw-bold small text-secondary">USER</label>
                    <select class="form-select form-control-lg" id="username" name="username" required>
                        <option value="" disabled selected>Select your user...</option>
                        <option value="emi">Emi</option>
                        <option value="deli">Deli</option>
                    </select>
                </div>

                <div class="mb-5">
                    <label for="password" class="form-label fw-bold small text-secondary">PASSWORD</label>
                    <input type="password" class="form-control form-control-lg" id="password" name="password" placeholder="••••••••" required>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 mb-4 fw-bold shadow-sm" style="border-radius: 15px;">Login securely <i class="fas fa-lock ms-2"></i></button>
            </form>

            <div class="position-relative text-center my-4">
                <hr class="text-secondary" style="opacity: 0.3;">
                <span class="position-absolute top-50 start-50 translate-middle px-3 text-secondary small fw-bold" style="background: rgba(255,255,255,0.9);">OR</span>
            </div>

            <!-- Guest Login Shortcut -->
            <form action="/login" method="POST">
                <input type="hidden" name="guestLogin" value="true">
                <button type="submit" class="btn w-100 py-3 fw-bold" style="border: 2px solid var(--primary-color); color: var(--primary-color); border-radius: 15px; background: transparent;">
                    Enter as Guest (Invitado) <i class="fas fa-user-circle ms-2"></i>
                </button>
            </form>
        </div>
    </div>
</div>
