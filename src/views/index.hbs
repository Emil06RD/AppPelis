<div class="row mb-5 fade-in">
    <div class="col-12 text-center">
        <h1 class="display-4 fw-bold mb-3">My <span class="text-primary">Collection</span></h1>
        <p class="text-secondary lead">Manage and track your watching progress.</p>
    </div>
</div>

<!-- Genre Filter Section: Collapsible Menu -->
<div class="row mb-5 fade-in">
    <div class="col-12 text-center">
        <div class="mb-4">
            <div class="d-inline-flex bg-white p-2 border border-2 border-dark rounded-pill gap-2 shadow-sm mb-2">
                <a href="/love-view/?{{#if currentGenreId}}genre={{currentGenreId}}&{{/if}}{{#if currentStatus}}status={{currentStatus}}{{/if}}" class="btn btn-sm {{#unless currentType}}btn-primary{{else}}btn-outline-accent{{/unless}} rounded-pill px-4 border-0">Todos</a>
                <a href="/love-view/?type=Serie{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentStatus}}&status={{currentStatus}}{{/if}}" class="btn btn-sm {{#if (eq currentType 'Serie')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Series</a>
                <a href="/love-view/?type=Pelicula{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentStatus}}&status={{currentStatus}}{{/if}}" class="btn btn-sm {{#if (eq currentType 'Pelicula')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Películas</a>
            </div>
            <div class="d-inline-flex bg-white p-2 border border-2 border-dark rounded-pill gap-2 shadow-sm mb-2 ms-md-2">
                <a href="/love-view/?{{#if currentGenreId}}genre={{currentGenreId}}&{{/if}}{{#if currentType}}type={{currentType}}{{/if}}" class="btn btn-sm {{#unless currentStatus}}btn-primary{{else}}btn-outline-accent{{/unless}} rounded-pill px-4 border-0">Todos los Estados</a>
                <a href="/love-view/?status=Watching{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentType}}&type={{currentType}}{{/if}}" class="btn btn-sm {{#if (eq currentStatus 'Watching')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Viendo</a>
                <a href="/love-view/?status=Plan to Watch{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentType}}&type={{currentType}}{{/if}}" class="btn btn-sm {{#if (eq currentStatus 'Plan to Watch')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Por ver</a>
                <a href="/love-view/?status=Watched{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentType}}&type={{currentType}}{{/if}}" class="btn btn-sm {{#if (eq currentStatus 'Watched')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Vistas</a>
            </div>
        </div>

        <button class="btn btn-genres-menu mb-4" type="button" data-bs-toggle="collapse" data-bs-target="#genreMenu" aria-expanded="false">
            <i class="fas fa-tags me-2"></i> EXPLORE GENRES ♥
        </button>
        
        <div class="collapse" id="genreMenu">
            <div class="genre-menu-card p-4">
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/love-view/?{{#if currentType}}type={{currentType}}&{{/if}}{{#if currentStatus}}status={{currentStatus}}{{/if}}" class="genre-pill {{#unless currentGenreId}}active{{/unless}}">
                        <i class="fas fa-th-large me-1"></i> All
                    </a>
                    {{#each genres}}
                    <a href="/love-view/?genre={{id}}{{#if ../currentType}}&type={{../currentType}}{{/if}}{{#if ../currentStatus}}&status={{../currentStatus}}{{/if}}" class="genre-pill {{#if (eq ../currentGenreId id)}}active{{/if}}">
                        <i class="fas fa-film me-1"></i> {{name}}
                    </a>
                    {{/each}}
                </div>
            </div>
        </div>

        {{#if currentGenreId}}
            <div class="mt-2">
                <span class="badge bg-primary px-3 py-2 rounded-pill">
                    Filtrando por: {{#each genres}}{{#if (eq ../currentGenreId id)}}{{name}}{{/if}}{{/each}}
                    <a href="/love-view/?{{#if currentType}}type={{currentType}}&{{/if}}{{#if currentStatus}}status={{currentStatus}}{{/if}}" class="text-white ms-2 text-decoration-none"><i class="fas fa-times-circle"></i></a>
                </span>
            </div>
        {{/if}}
    </div>
</div>


<!-- Section: Watching -->
{{#if showWatching}}
<div class="mb-5 fade-in">
    <h2 class="fw-bold mb-4">♥ Watching (Viendo)</h2>
    <div class="row g-4">
        {{#if watching.length}}
            {{#each watching}}
            <div class="col-md-6 col-lg-4">
                <div class="series-name-card position-relative fade-in">
                    <h5 class="fw-bold mb-0 series-title-hover">{{title}}</h5>
                    <div class="hover-poster-container">
                        <img src="{{posterUrl}}" alt="{{title}}" class="hover-poster">
                        <div class="hover-info">
                            <p class="mb-0 small fw-bold text-white">{{Genre.name}}{{#if Genre2.name}} · {{Genre2.name}}{{/if}}{{#if Genre3.name}} · {{Genre3.name}}{{/if}}{{#if Genre4.name}} · {{Genre4.name}}{{/if}}</p>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="rating-badge-mini">
                                    <i class="fas fa-star text-warning x-small"></i>
                                    <span class="x-small fw-bold">{{#if ratingAverage}}{{ratingAverage}}{{else}}0.0{{/if}}</span>
                                </div>
                                <div class="x-small text-white-50">
                                    E: {{#if ratingEmil}}{{ratingEmil}}{{else}}0{{/if}} | D: {{#if ratingDeli}}{{ratingDeli}}{{else}}0{{/if}}
                                </div>
                            </div>
                            {{#if (eq type 'Serie')}}
                                <p class="mb-0 fw-bold x-small" style="color: var(--accent-color);">Season {{season}}</p>
                            {{else}}
                                <p class="mb-0 x-small text-white-50">Película</p>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        {{else}}
            <div class="col-12"><p class="text-secondary italic">No series currently being watched.</p></div>
        {{/if}}
    </div>
</div>
{{/if}}

<!-- Section: Watched -->
{{#if showWatched}}
<div class="mb-5 fade-in">
    <h2 class="fw-bold mb-4">♥ Watched (Vistas)</h2>
    <div class="row g-4">
        {{#if watched.length}}
            {{#each watched}}
            <div class="col-md-6 col-lg-4">
                <div class="series-name-card position-relative fade-in" style="opacity: 0.8;">
                    <h5 class="fw-bold mb-0 series-title-hover">{{title}}</h5>
                    <div class="hover-poster-container">
                        <img src="{{posterUrl}}" alt="{{title}}" class="hover-poster">
                        <div class="hover-info">
                            <p class="mb-0 small fw-bold text-white">{{Genre.name}}{{#if Genre2.name}} · {{Genre2.name}}{{/if}}{{#if Genre3.name}} · {{Genre3.name}}{{/if}}{{#if Genre4.name}} · {{Genre4.name}}{{/if}}</p>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="rating-badge-mini">
                                    <i class="fas fa-star text-warning x-small"></i>
                                    <span class="x-small fw-bold">{{#if ratingAverage}}{{ratingAverage}}{{else}}0.0{{/if}}</span>
                                </div>
                                <div class="x-small text-white-50">
                                    E: {{#if ratingEmil}}{{ratingEmil}}{{else}}0{{/if}} | D: {{#if ratingDeli}}{{ratingDeli}}{{else}}0{{/if}}
                                </div>
                            </div>
                            {{#if (eq type 'Serie')}}
                                <p class="mb-0 fw-bold x-small" style="color: var(--accent-color);">Season {{season}}</p>
                            {{else}}
                                <p class="mb-0 x-small text-white-50">Película</p>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        {{else}}
            <div class="col-12"><p class="text-secondary italic">No series watched yet.</p></div>
        {{/if}}
    </div>
</div>
{{/if}}

<!-- Section: Plan to Watch -->
{{#if showPlanToWatch}}
<div class="mb-5 fade-in">
    <h2 class="fw-bold mb-4">♥ Plan to Watch (Por ver)</h2>
    <div class="row g-4">
        {{#if planToWatch.length}}
            {{#each planToWatch}}
            <div class="col-md-6 col-lg-4">
                <div class="series-name-card position-relative fade-in">
                    <h5 class="fw-bold mb-0 series-title-hover">{{title}}</h5>
                    <div class="hover-poster-container">
                        <img src="{{posterUrl}}" alt="{{title}}" class="hover-poster">
                        <div class="hover-info">
                            <p class="mb-0 small fw-bold text-white">{{Genre.name}}{{#if Genre2.name}} · {{Genre2.name}}{{/if}}{{#if Genre3.name}} · {{Genre3.name}}{{/if}}{{#if Genre4.name}} · {{Genre4.name}}{{/if}}</p>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="rating-badge-mini">
                                    <i class="fas fa-star text-warning x-small"></i>
                                    <span class="x-small fw-bold">{{#if ratingAverage}}{{ratingAverage}}{{else}}0.0{{/if}}</span>
                                </div>
                                <div class="x-small text-white-50">
                                    E: {{#if ratingEmil}}{{ratingEmil}}{{else}}0{{/if}} | D: {{#if ratingDeli}}{{ratingDeli}}{{else}}0{{/if}}
                                </div>
                            </div>
                            {{#if (eq type 'Serie')}}
                                <p class="mb-0 fw-bold x-small" style="color: var(--accent-color);">Season {{season}}</p>
                            {{else}}
                                <p class="mb-0 x-small text-white-50">Película</p>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        {{else}}
            <div class="col-12"><p class="text-secondary italic">No series in your watchlist.</p></div>
        {{/if}}
    </div>
</div>
{{/if}}
