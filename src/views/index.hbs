<script>
document.addEventListener('DOMContentLoaded', function () {
    // Elevate column z-index on hover so poster popup floats above siblings
    document.querySelectorAll('.series-name-card').forEach(function (card) {
        const col = card.closest('[class*="col"]');
        if (!col) return;
        
        col.style.position = 'relative';

        card.addEventListener('mouseenter', function () {
            col.style.zIndex = '200';
        });
        card.addEventListener('mouseleave', function () {
            col.style.zIndex = '';
        });
    });

    document.querySelectorAll('[data-cascade]').forEach(function (card) {
        card.addEventListener('click', function () {
            const targetId = card.getAttribute('data-cascade');
            const wrapper = document.getElementById(targetId);
            if (!wrapper) return;

            const isOpen = wrapper.classList.contains('cascade-open');
            const chevron = card.querySelector('.cascade-chevron');

            if (isOpen) {
                wrapper.classList.remove('cascade-open');
                card.classList.remove('cascade-active');
                if (chevron) chevron.style.transform = 'rotate(0deg)';
            } else {
                wrapper.classList.add('cascade-open');
                card.classList.add('cascade-active');
                if (chevron) chevron.style.transform = 'rotate(180deg)';

                // Animate entry for children
                wrapper.querySelectorAll('.cascade-item').forEach(function (item, i) {
                    item.style.opacity = '0';
                    item.style.transform = 'translateY(-10px) scale(0.95)';
                    setTimeout(function () {
                        item.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
                        item.style.opacity = '1';
                        item.style.transform = 'translateY(0) scale(1)';
                    }, i * 60);
                });
            }
        });
    });
});
</script>