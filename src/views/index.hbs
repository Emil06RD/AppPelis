<div class="row mb-5 fade-in">
    <div class="col-12 text-center">
        <h1 class="display-4 fw-bold mb-3">My <span class="text-primary">Collection</span></h1>
        <p class="text-secondary lead">Manage and track your watching progress.</p>
    </div>
</div>

<!-- Filters -->
<div class="row mb-5 fade-in">
    <div class="col-12 text-center">
        <div class="mb-4">
            <div class="d-inline-flex bg-white p-2 border border-2 border-dark rounded-pill gap-2 shadow-sm mb-2">
                <a href="/love-view/?{{#if currentGenreId}}genre={{currentGenreId}}{{/if}}{{#if currentStatus}}{{#if currentGenreId}}&{{/if}}status={{currentStatus}}{{/if}}"
                    class="btn btn-sm {{#unless currentType}}btn-primary{{else}}btn-outline-accent{{/unless}} rounded-pill px-4 border-0">Todos</a>
                <a href="/love-view/?type=Serie{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentStatus}}&status={{currentStatus}}{{/if}}"
                    class="btn btn-sm {{#if (eq currentType 'Serie')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Series</a>
                <a href="/love-view/?type=Pelicula{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentStatus}}&status={{currentStatus}}{{/if}}"
                    class="btn btn-sm {{#if (eq currentType 'Pelicula')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Películas</a>
            </div>
            <div class="d-inline-flex bg-white p-2 border border-2 border-dark rounded-pill gap-2 shadow-sm mb-2 ms-md-2">
                <a href="/love-view/?{{#if currentGenreId}}genre={{currentGenreId}}{{/if}}{{#if currentType}}{{#if currentGenreId}}&{{/if}}type={{currentType}}{{/if}}"
                    class="btn btn-sm {{#unless currentStatus}}btn-primary{{else}}btn-outline-accent{{/unless}} rounded-pill px-4 border-0">Todos los Estados</a>
                <a href="/love-view/?status=Watching{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentType}}&type={{currentType}}{{/if}}"
                    class="btn btn-sm {{#if (eq currentStatus 'Watching')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Viendo</a>
                <a href="/love-view/?status=Plan to Watch{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentType}}&type={{currentType}}{{/if}}"
                    class="btn btn-sm {{#if (eq currentStatus 'Plan to Watch')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Por ver</a>
                <a href="/love-view/?status=Watched{{#if currentGenreId}}&genre={{currentGenreId}}{{/if}}{{#if currentType}}&type={{currentType}}{{/if}}"
                    class="btn btn-sm {{#if (eq currentStatus 'Watched')}}btn-primary{{else}}btn-outline-accent{{/if}} rounded-pill px-4 border-0">Vistas</a>
            </div>
        </div>

        <button class="btn btn-genres-menu mb-4" type="button" data-bs-toggle="collapse" data-bs-target="#genreMenu" aria-expanded="false">
            <i class="fas fa-tags me-2"></i> EXPLORE GENRES ♥
        </button>
        <div class="collapse" id="genreMenu">
            <div class="genre-menu-card p-4">
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/love-view/?{{#if currentType}}type={{currentType}}{{/if}}{{#if currentStatus}}{{#if currentType}}&{{/if}}status={{currentStatus}}{{/if}}"
                        class="genre-pill {{#unless currentGenreId}}active{{/unless}}">
                        <i class="fas fa-th-large me-1"></i> All
                    </a>
                    {{#each genres}}
                    <a href="/love-view/?genre={{id}}{{#if ../currentType}}&type={{../currentType}}{{/if}}{{#if ../currentStatus}}&status={{../currentStatus}}{{/if}}"
                        class="genre-pill {{#if (eq ../currentGenreId id)}}active{{/if}}">
                        <i class="fas fa-film me-1"></i> {{name}}
                    </a>
                    {{/each}}
                </div>
            </div>
        </div>
        {{#if currentGenreId}}
        <div class="mt-2">
            <span class="badge bg-primary px-3 py-2 rounded-pill">
                Filtrando por: {{#each genres}}{{#if (eq ../currentGenreId id)}}{{name}}{{/if}}{{/each}}
                <a href="/love-view/?{{#if currentType}}type={{currentType}}{{/if}}{{#if currentStatus}}{{#if currentType}}&{{/if}}status={{currentStatus}}{{/if}}"
                    class="text-white ms-2 text-decoration-none"><i class="fas fa-times-circle"></i></a>
            </span>
        </div>
        {{/if}}
    </div>
</div>


<!-- ===== Section: Watching ===== -->
{{#if showWatching}}
<div class="mb-5 fade-in">
    <h2 class="fw-bold mb-4">♥ Watching</h2>
    <div class="row g-4" id="grid-watching">
        {{#if watching.length}}
        {{#each watching}}

        <div class="col-md-6 col-lg-4">
            <div class="series-name-card position-relative fade-in {{#if (gt count 1)}}grouped-card{{/if}}"
                 {{#if (gt count 1)}}data-cascade="cascade-w-{{@index}}"{{/if}}>
                {{#if (gt count 1)}}<span class="group-count-badge">{{count}} entradas</span>{{/if}}
                <h5 class="fw-bold mb-0 series-title-hover">
                    {{title}}
                    {{#if (gt count 1)}}<i class="fas fa-chevron-down ms-2 cascade-chevron x-small"></i>{{/if}}
                </h5>
                <div class="hover-poster-container">
                    <img src="{{posterUrl}}" alt="{{title}}" class="hover-poster">
                    <div class="hover-info text-start">
                        <p class="mb-0 small fw-bold text-white">{{Genre.name}}{{#if Genre2.name}} · {{Genre2.name}}{{/if}}</p>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div class="rating-badge-mini">
                                <i class="fas fa-star text-warning x-small"></i>
                                <span class="x-small fw-bold">{{#if ratingAverage}}{{ratingAverage}}{{else}}0.0{{/if}}</span>
                            </div>
                            <div class="x-small text-white-50">E: {{#if ratingEmil}}{{ratingEmil}}{{else}}0{{/if}} | D: {{#if ratingDeli}}{{ratingDeli}}{{else}}0{{/if}}</div>
                        </div>
                        {{!-- Season/Movie label removed from main card --}}
                    </div>
                </div>
            </div>
        </div>

        {{!-- Expansion Wrapper (Sibling in grid) --}}
        {{#if (gt count 1)}}
        <div class="cascade-wrapper" id="cascade-w-{{@index}}">
            {{#each items}}
            <div class="col-md-6 col-lg-4 cascade-item">
                <div class="series-name-card position-relative fade-in">
                    <h5 class="fw-bold mb-0 series-title-hover">
                        {{#if (eq type 'Serie')}}Season {{season}}{{else}}Movie{{/if}}
                    </h5>
                    <div class="hover-poster-container">
                        <img src="{{posterUrl}}" alt="{{../title}}" class="hover-poster">
                        <div class="hover-info text-start">
                            <p class="mb-0 small fw-bold text-white">{{Genre.name}}{{#if Genre2.name}} · {{Genre2.name}}{{/if}}</p>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="rating-badge-mini">
                                    <i class="fas fa-star text-warning x-small"></i>
                                    <span class="x-small fw-bold">{{#if ratingAverage}}{{ratingAverage}}{{else}}0.0{{/if}}</span>
                                </div>
                                <div class="x-small text-white-50">E: {{#if ratingEmil}}{{ratingEmil}}{{else}}0{{/if}} D: {{#if ratingDeli}}{{ratingDeli}}{{else}}0{{/if}}</div>
                            </div>
                            <p class="mb-0 x-small text-white-50">{{#if (eq type 'Serie')}}Season {{season}}{{else}}Movie{{/if}}</p>
                            <div class="d-flex align-items-center justify-content-between mt-1">
                                <span class="badge bg-dark-accent x-small">{{status}}</span>
                                <a href="/love-view/edit/{{id}}" class="btn btn-sm btn-outline-light cascade-edit-btn" style="font-size: 0.6rem;">Editar</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}

        {{/each}}
        {{else}}
        <div class="col-12"><p class="text-secondary italic">No series currently being watched.</p></div>
        {{/if}}
    </div>
</div>
{{/if}}

